---
import styles from './ScrollClock.module.css';

interface Props {
    degPerViewport?: number;
    snapScrollDist?: number;
    fadeBand?:       number;
    activeBand?:     number;
}

const {
    degPerViewport = 45,
    snapScrollDist = 7.5,
    fadeBand       = 15,
    activeBand     = 15,
} = Astro.props;
---

<div
    id="scroll-clock"
    class={styles.wrap}
    aria-hidden="true"
    role="presentation"
    data-deg-per-viewport={degPerViewport}
    data-snap-scroll-dist={snapScrollDist}
    data-fade-band={fadeBand}
    data-active-band={activeBand}
>
    <div id="sc-face" class={styles.face}>
        <div class={styles.plate} />
        <div class={`${styles.ring} ${styles.ring_outer}`} />

        <div class={styles.numeral} style="--i: 1">I</div>
        <div class={styles.numeral} style="--i: 2">II</div>
        <div class={styles.numeral} style="--i: 3">III</div>
        <div class={styles.numeral} style="--i: 4">IV</div>
        <div class={styles.numeral} style="--i: 5">V</div>
        <div class={styles.numeral} style="--i: 6">VI</div>
        <div class={styles.numeral} style="--i: 7">VII</div>
        <div class={styles.numeral} style="--i: 8">VIII</div>
        <div class={styles.numeral} style="--i: 9">IX</div>
        <div class={styles.numeral} style="--i: 10">X</div>
        <div class={styles.numeral} style="--i: 11">XI</div>
        <div class={styles.numeral} style="--i: 12">XII</div>

        <div class={styles.hands}>
            <div class={styles.jewel} />
            <div id="sc-hand-minute" class={`${styles.hand} ${styles.hand_minute}`} />
            <div id="sc-hand-hour"   class={`${styles.hand} ${styles.hand_hour}`}   />
        </div>
    </div>

    <div id="sc-markers" class={styles.markers} />
</div>

<script src="./ScrollClock.ts"></script>
