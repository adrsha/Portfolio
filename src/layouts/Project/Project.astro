---
import styles from "./Project.module.css";
import FullScreenImage from "@components/FullScreenImage/FullScreenImage.astro";

interface Node_Item {
    label: string;
    items: string[];
};

interface Props {
    title:       string;
    description: string;
    link?:       string;
    image?:      string;
    skills?:     string[];
    year?:       string | number;
};

const {
    title,
    description,
    link,
    image,
    skills = [],
    year,
} = Astro.props;

const nodes: Node_Item[] = [];

if (skills.length > 0) nodes.push({ label: "Skills",  items: skills });
if (image)             nodes.push({ label: "Preview", items: [image] });
if (year)              nodes.push({ label: "Year",    items: [String(year)] });
---

<article class={styles.project}>

    <div class={styles.info}>
        <h2 class={styles.title}>{title}</h2>
        <p  class={styles.description}>{description}</p>
        {link && (
            <a href={link} target="_blank" rel="noopener noreferrer" class={styles.visitBtn}>
                Visit Project ↗
            </a>
        )}
    </div>

    <div class={styles.diagram} aria-hidden="true"  data-scroll data-scroll-dir="top" data-scroll-speed="2">

        <div class={styles.rail}></div>

        <div class={styles.nodes}>
            {nodes.map((node, i) => {
                const path_id = `circlePath_${title.replace(/\s+/g, '_')}_${i}`;
                return (
                    <div
                        class={styles.nodeWrap}
                        style={`--node-index: ${i};`}
                    >
                        <div class={styles.nodeCard}>
                            <span class={styles.nodeLabel}>{node.label}</span>
                            <ul class={styles.nodeItems}>
                                {node.items.map(item =>
                                    node.label === "Preview" ? (
                                        <FullScreenImage src={item} alt={`${title} preview`} class={styles.previewImg} />
                                    ) : (
                                        <li>{item}</li>
                                    )
                                )}
                            </ul>
                        </div>
                        <div class={styles.stem}></div>
                        <div class={styles.nodeCircle} data-cursor-type={"hover"}>
                            <svg viewBox="0 0 50 50" width="150" height="150">
                                <path id={path_id} d="M 25,25 m -11,0 a 11,11 0 1,1 22,0 a 11,11 0 1,1 -22,0" fill="none" />
                                <text font-size="6">
                                    <textPath href={`#${path_id}`} startOffset="50%" text-anchor="middle">
                                        {node.label}
                                    </textPath>
                                </text>
                            </svg>
                        </div>
                    </div>
                );
            })}
        </div>

    </div>

</article>

<script src="./Project.ts"></script>
